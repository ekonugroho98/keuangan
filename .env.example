
# ─────────────────────────────────────────────────────────────
# Karaya Finance — Environment Variables
# Salin file ini menjadi .env lalu isi dengan nilai milikmu
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Supabase — dapatkan dari: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Karaya API (Backend) — URL deployment Vercel karaya-api milikmu
# Jika tidak diisi, akan menggunakan default karaya-api publik
VITE_API_BASE_URL=https://your-karaya-api.vercel.app
