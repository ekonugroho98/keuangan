
# ─────────────────────────────────────────────────────────────
# Karaya Finance — Environment Variables
# Salin file ini menjadi .env lalu isi dengan nilai milikmu
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Supabase — dapatkan dari: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Nama Aplikasi — ubah sesuai nama brand kamu (opsional, default: Karaya)
VITE_APP_NAME=Karaya
VITE_APP_TAGLINE=Wealth Ledger
